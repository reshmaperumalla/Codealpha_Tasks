<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Credit Scoring Model</title>

<style>

body{
    margin:0;
    padding:0;
    font-family:Arial, sans-serif;
    background:#f2f2f2;
}

.container{
    width:90%;
    max-width:900px;
    margin:40px auto;
    background:white;
    padding:30px;
    border-radius:15px;
    box-shadow:0 0 15px rgba(0,0,0,0.2);
}

h1{
    text-align:center;
    color:#2c3e50;
}

.section{
    margin-top:25px;
}

label{
    font-weight:bold;
    display:block;
    margin-top:10px;
}

input{
    width:100%;
    padding:10px;
    margin-top:5px;
    border:1px solid #ccc;
    border-radius:8px;
    font-size:16px;
}

button{
    width:100%;
    margin-top:25px;
    padding:12px;
    background:#27ae60;
    color:white;
    border:none;
    border-radius:10px;
    font-size:18px;
    cursor:pointer;
}

button:hover{
    background:#219150;
}

.result{
    margin-top:25px;
    padding:20px;
    background:#ecf0f1;
    border-radius:10px;
    font-size:20px;
    text-align:center;
    font-weight:bold;
}

.features{
    margin-top:20px;
    background:#fafafa;
    padding:15px;
    border-radius:10px;
}

.features ul{
    line-height:1.8;
}

</style>
</head>

<body>

<div class="container">

<h1>✅ Credit Scoring Model</h1>

<div class="section">
<h2>Objective</h2>
<p>
Predict an individual's <b>creditworthiness</b> using past financial data.
</p>
</div>

<div class="section">
<h2>Enter Financial Details</h2>

<label>Monthly Income (₹)</label>
<input type="number" id="income" placeholder="Enter income">

<label>Total Debt (₹)</label>
<input type="number" id="debt" placeholder="Enter debt">

<label>Payment History (%)</label>
<input type="number" id="payment" placeholder="Enter payment history">

<label>Credit Utilization (%)</label>
<input type="number" id="utilization" placeholder="Enter credit utilization">

<button onclick="calculateScore()">
Check Credit Score
</button>

<div class="result" id="result">
Your result will appear here
</div>

</div>

<div class="features">
<h2>Key Features</h2>

<ul>
<li>Feature engineering from financial history</li>
<li>Uses classification concepts like Logistic Regression & Random Forest</li>
<li>Evaluates Precision, Recall, F1-Score, ROC-AUC</li>
<li>Dataset includes income, debts, payment history, etc.</li>
</ul>

</div>

</div>

<script>

function calculateScore(){

    let income = parseFloat(document.getElementById("income").value);
    let debt = parseFloat(document.getElementById("debt").value);
    let payment = parseFloat(document.getElementById("payment").value);
    let utilization = parseFloat(document.getElementById("utilization").value);

    let score = 0;

    // Income Score
    if(income >= 100000){
        score += 40;
    }
    else if(income >= 50000){
        score += 25;
    }
    else{
        score += 10;
    }

    // Debt Score
    if(debt <= 20000){
        score += 30;
    }
    else if(debt <= 50000){
        score += 15;
    }
    else{
        score += 5;
    }

    // Payment History
    if(payment >= 90){
        score += 20;
    }
    else if(payment >= 70){
        score += 10;
    }
    else{
        score += 5;
    }

    // Credit Utilization
    if(utilization <= 30){
        score += 10;
    }
    else if(utilization <= 60){
        score += 5;
    }

    let result = "";

    if(score >= 80){
        result = "🟢 Excellent Creditworthiness";
    }
    else if(score >= 60){
        result = "🟡 Good Creditworthiness";
    }
    else{
        result = "🔴 Poor Creditworthiness";
    }

    document.getElementById("result").innerHTML =
    "Credit Score: " + score + "<br>" + result;
}

</script>

</body>
</html>
